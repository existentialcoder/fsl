@prefix ve:   <http://www.softlang.org/ontologies/ve#> .
@prefix sh:   <http://www.w3.org/ns/shacl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ve:MetamodellingArtifactEntityShape
  a sh:NodeShape ;
  sh:targetSubjectsOf rdfs:subClassOf ;
  sh:sparql [
    a sh:SPARQLConstraint ;
    sh:message "Anything below the immediate subclasses of tbox:ArtifactEntity must be of type tbox:ArtifactEntity." ;
    sh:select """
      PREFIX tbox: <http://www.softlang.org/ontologies/tbox#>
      PREFIX rdf:  <http://www.w3.org/1999/02/22-rdf-syntax-ns#>
      PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

      SELECT $this
      WHERE {
        FILTER($this != owl:Nothing)
      	$this rdfs:subClassOf ?super .
      	?super rdfs:subClassOf+ tbox:ArtifactEntity .
        FILTER NOT EXISTS {
          $this rdf:type tbox:ArtifactEntity .
        }
      }
    """ ;
  ] .

