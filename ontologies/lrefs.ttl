    tbox:hasDOI "10.1145/1072997.1073000" ;
    tbox:hasEntryType "article" ;
    tbox:hasInclusionRoleComment "Establishes grammarware as a coherent engineering ecosystem, providing a concrete example of a technological space in practice." ;
