@prefix tbox: <http://www.softlang.org/ontologies/tbox#> .
@prefix te: <http://www.softlang.org/ontologies/te#> .

<http://www.softlang.org/ontologies/ce> a owl:Ontology ;
    rdfs:comment "Sub-ontology / ABox for conceptual entities"@en,
        "This module also hosts the reusable language-concept framework used across software-language modules."@en ;
    owl:imports <http://www.softlang.org/ontologies/tbox> .

ce:Abstraction a ce:AbstractionConcept,
        tbox:ConceptualEntity ;
    rdfs:label "abstraction"@en ;
    rdfs:seeAlso <https://en.wikipedia.org/wiki/Abstraction_(computer_science)> ;
    owl:sameAs <https://dbpedia.org/resource/Abstraction_(computer_science)> .

ce:Actors a ce:CompositeConcept,
        tbox:ConceptualEntity ;
    rdfs:label "actors"@en ;
    ce:hasPrimaryComponent ce:ActorBasedConcurrency,
        ce:Encapsulation,
        ce:VariablesAsState ;
    ce:hasSecondaryComponent ce:MessagePassingConcurrency,
        ce:Modules,
        ce:SideEffects ;
    rdfs:seeAlso <https://en.wikipedia.org/wiki/Actor_model> ;
    owl:sameAs <https://dbpedia.org/resource/Actor_model> .

ce:AdHocPolymorphism a ce:TypeConcept,
